<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>User Login / Signup</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    :root {
      /* KIIT Blue → Green Gradient */
      --bg-gradient: linear-gradient(135deg, #00224d, #0052cc, #00c853);

      /* Card + Surface */
      --card-bg: rgba(3, 15, 30, 0.9);

      /* KIIT Green Accent */
      --accent: #00c853;
      --accent-soft: rgba(0, 200, 83, 0.18);
      --accent-strong: #00a143;

      /* Text Colors */
      --text-main: #e6f4ea;
      --text-muted: #9fb3c8;

      /* Inputs + Borders */
      --input-bg: rgba(3, 18, 36, 0.95);
      --border-subtle: rgba(148, 163, 184, 0.45);

      /* Shadow + Radius */
      --shadow-soft: 0 24px 48px rgba(3, 10, 23, 0.85);
      --radius-xl: 1.5rem;
      --transition-fast: 0.2s ease;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
        sans-serif;
    }

    body {
      min-height: 100vh;
      background-image: var(--bg-gradient);
      background-size: 200% 200%;
      animation: gradientShift 12s ease infinite;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
      color: var(--text-main);
    }

    @keyframes gradientShift {
      0% {
        background-position: 0% 50%;
      }
      50% {
        background-position: 100% 50%;
      }
      100% {
        background-position: 0% 50%;
      }
    }

    .auth-wrapper {
      width: 100%;
      max-width: 960px;
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
      gap: 2.5rem;
      align-items: stretch;
    }

    /* Left info panel */
    .info-card {
      background: radial-gradient(circle at top left, #22c55e33, transparent),
        radial-gradient(circle at bottom right, #60a5fa33, transparent),
        var(--card-bg);
      border-radius: var(--radius-xl);
      padding: 2rem 2.25rem;
      box-shadow: var(--shadow-soft);
      border: 1px solid rgba(148, 163, 184, 0.35);
      position: relative;
      overflow: hidden;
    }

    .info-card::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image: radial-gradient(
        circle at 10% 20%,
        rgba(96, 165, 250, 0.3) 0,
        transparent 50%
      );
      opacity: 0.4;
      pointer-events: none;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.2rem 0.7rem;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.65);
      border: 1px solid rgba(148, 163, 184, 0.5);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--text-muted);
    }

    .badge-dot {
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: var(--accent);
      box-shadow: 0 0 10px rgba(34, 197, 94, 0.9);
    }

    .info-title {
      font-size: 2rem;
      line-height: 1.2;
      margin-top: 1.25rem;
      margin-bottom: 0.75rem;
    }

    .info-highlight {
      color: var(--accent);
    }

    .info-subtitle {
      color: var(--text-muted);
      font-size: 0.95rem;
      max-width: 28rem;
      margin-bottom: 1.75rem;
    }

    .info-stats {
      display: flex;
      flex-wrap: wrap;
      gap: 1.25rem;
      margin-bottom: 2rem;
    }

    .stat {
      min-width: 120px;
    }

    .stat-value {
      font-size: 1.5rem;
      font-weight: 600;
    }

    .stat-label {
      font-size: 0.8rem;
      color: var(--text-muted);
    }

    .pill-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .pill {
      padding: 0.5rem 0.85rem;
      border-radius: 999px;
      font-size: 0.75rem;
      background: rgba(15, 23, 42, 0.85);
      border: 1px solid rgba(148, 163, 184, 0.35);
      color: var(--text-muted);
    }

    .pill strong {
      color: var(--accent);
      font-weight: 500;
    }

    /* Right auth card */
    .auth-card {
      background: rgba(15, 23, 42, 0.95);
      border-radius: var(--radius-xl);
      padding: 2rem 2.25rem 2.3rem;
      box-shadow: var(--shadow-soft);
      border: 1px solid rgba(148, 163, 184, 0.45);
      backdrop-filter: blur(20px);
      position: relative;
      overflow: hidden;
    }

    .auth-card::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: radial-gradient(
        circle at 0% 0%,
        rgba(0, 200, 83, 0.18),
        transparent 55%
      );
      opacity: 0.9;
    }

    .auth-card-inner {
      position: relative;
      z-index: 1;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      margin-bottom: 1.5rem;
    }

    .brand-logo {
      width: 30px;
      height: 30px;
      border-radius: 0.9rem;
      border: 1px solid rgba(148, 163, 184, 0.7);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.9rem;
      font-weight: 600;
      background: radial-gradient(circle at 30% 0%, #00c85355, #0b1120);
      box-shadow: 0 10px 18px rgba(15, 23, 42, 0.75);
    }

    .brand-text {
      font-weight: 500;
      letter-spacing: 0.06em;
      font-size: 0.8rem;
      color: var(--text-muted);
      text-transform: uppercase;
    }

    /* Hide radio buttons for tabs */
    .tab-input {
      display: none;
    }

    /* Tabs */
    .tabs {
      display: flex;
      gap: 0.8rem;
      padding: 0.25rem;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.85);
      border: 1px solid rgba(148, 163, 184, 0.4);
      margin-bottom: 1.6rem;
    }

    .tab-label {
      flex: 1;
      text-align: center;
      padding: 0.55rem 0.8rem;
      font-size: 0.85rem;
      border-radius: 999px;
      cursor: pointer;
      color: var(--text-muted);
      position: relative;
      transition: background var(--transition-fast), color var(--transition-fast),
        transform var(--transition-fast);
      user-select: none;
    }

    .tab-label span {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      justify-content: center;
    }

    .tab-label .dot {
      width: 7px;
      height: 7px;
      border-radius: 999px;
      background: rgba(148, 163, 184, 0.9);
    }

    /* Active tab styling – note the ~ .tabs ... */
    #tab-login:checked ~ .tabs label[for="tab-login"],
    #tab-signup:checked ~ .tabs label[for="tab-signup"] {
      background: radial-gradient(circle at top, var(--accent-soft), #111827);
      color: #f9fafb;
      transform: translateY(-1px);
    }

    #tab-login:checked ~ .tabs label[for="tab-login"] .dot,
    #tab-signup:checked ~ .tabs label[for="tab-signup"] .dot {
      background: var(--accent);
      box-shadow: 0 0 10px rgba(0, 200, 83, 0.9);
    }

.form-outer {
  position: relative;
  min-height: auto;     /* ✅ NO fixed height */
}

.form-panel {
  display: none;        /* ✅ hide inactive form cleanly */
  transform: translateY(6px);
  transition: transform 0.25s ease;
}

/* Show only the active form */
#tab-login:checked ~ .form-outer .form-login {
  display: block;
  transform: translateY(0);
}

#tab-signup:checked ~ .form-outer .form-signup {
  display: block;
  transform: translateY(0);
}

    .form-title {
      font-size: 1.25rem;
      margin-bottom: 0.4rem;
    }

    .form-desc {
      font-size: 0.82rem;
      color: var(--text-muted);
      margin-bottom: 1.2rem;
    }

    .form-row {
      margin-bottom: 0.95rem;
    }

    .form-row-inline {
      display: flex;
      gap: 0.75rem;
    }

    .form-label {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      font-size: 0.8rem;
      margin-bottom: 0.25rem;
      color: var(--text-muted);
    }

    .form-label span.main {
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 500;
      font-size: 0.7rem;
    }

    .form-input,
    .form-select {
      width: 100%;
      padding: 0.7rem 0.75rem;
      border-radius: 0.9rem;
      border: 1px solid var(--border-subtle);
      background: var(--input-bg);
      color: var(--text-main);
      font-size: 0.85rem;
      outline: none;
      transition: border var(--transition-fast),
        box-shadow var(--transition-fast), background var(--transition-fast),
        transform var(--transition-fast);
    }

    .form-input::placeholder {
      color: rgba(148, 163, 184, 0.65);
    }

    .form-input:focus,
    .form-select:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 1px rgba(0, 200, 83, 0.5),
        0 0 0 12px rgba(0, 200, 83, 0.06);
      transform: translateY(-1px);
    }

    .form-helper {
      font-size: 0.7rem;
      color: #6b7280;
      margin-top: 0.15rem;
    }

    .actions {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: 1rem;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .btn-primary {
      flex: 1;
      border: none;
      border-radius: 999px;
      padding: 0.7rem 1rem;
      font-size: 0.88rem;
      font-weight: 500;
      cursor: pointer;
      background: radial-gradient(circle at top, var(--accent), var(--accent-strong));
      color: #f9fafb;
      box-shadow: 0 12px 24px rgba(0, 200, 83, 0.5);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.45rem;
      transition: transform var(--transition-fast),
        box-shadow var(--transition-fast), filter var(--transition-fast);
    }

    .btn-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 16px 32px rgba(0, 200, 83, 0.7);
      filter: brightness(1.02);
    }

    .btn-primary:active {
      transform: translateY(0);
      box-shadow: 0 10px 20px rgba(0, 200, 83, 0.45);
      filter: brightness(0.98);
    }

    .btn-secondary {
      border: none;
      background: transparent;
      color: var(--text-muted);
      font-size: 0.8rem;
      cursor: pointer;
      padding: 0;
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-color: rgba(148, 163, 184, 0.7);
      transition: color var(--transition-fast),
        text-decoration-color var(--transition-fast),
        transform var(--transition-fast);
    }

    .btn-secondary:hover {
      color: var(--accent);
      text-decoration-color: rgba(0, 200, 83, 0.9);
      transform: translateY(-0.5px);
    }

    .forgot-link {
      font-size: 0.8rem;
      text-decoration: none;
      color: var(--text-muted);
      transition: color var(--transition-fast), transform var(--transition-fast);
    }

    .forgot-link:hover {
      color: var(--accent);
      transform: translateY(-0.5px);
    }

    .vehicle-type-group {
      display: flex;
      gap: 0.5rem;
    }

    .vehicle-chip {
      flex: 1;
      border-radius: 999px;
      padding: 0.45rem 0.65rem;
      font-size: 0.78rem;
      border: 1px solid var(--border-subtle);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      cursor: pointer;
      background: var(--input-bg);
      color: var(--text-muted);
      transition: background var(--transition-fast), color var(--transition-fast),
        border var(--transition-fast), transform var(--transition-fast);
    }

    .vehicle-chip input {
      display: none;
    }

    .vehicle-chip span.icon {
      font-size: 0.9rem;
    }

    .vehicle-chip span.text {
      text-transform: uppercase;
      letter-spacing: 0.09em;
      font-size: 0.68rem;
    }

    .vehicle-chip input:checked + .chip-inner {
      background: var(--accent-soft);
      border-color: var(--accent);
      color: #ecfdf5;
      transform: translateY(-1px);
    }

    .vehicle-chip input:checked + .chip-inner .icon {
      filter: drop-shadow(0 0 8px rgba(0, 200, 83, 0.8));
    }

    .agreement {
      margin-top: 0.35rem;
      font-size: 0.7rem;
      color: var(--text-muted);
    }

    .agreement a {
      color: var(--accent);
      text-decoration: none;
    }

    .agreement a:hover {
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .divider {
      margin-top: 1.4rem;
      font-size: 0.72rem;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      gap: 0.7rem;
    }

    .divider::before,
    .divider::after {
      content: "";
      flex: 1;
      height: 1px;
      background: radial-gradient(circle, rgba(148, 163, 184, 0.7), transparent);
      opacity: 0.55;
    }

    .mini-note {
      margin-top: 0.7rem;
      font-size: 0.7rem;
      color: #6b7280;
    }

    /* Responsive */
    @media (max-width: 900px) {
      .auth-wrapper {
        grid-template-columns: minmax(0, 1fr);
        max-width: 560px;
      }

      .info-card {
        order: 2;
        padding: 1.6rem 1.8rem;
      }

      .auth-card {
        order: 1;
      }
    }

    @media (max-width: 640px) {
      body {
        padding: 1.3rem 0.75rem;
      }

      .auth-card,
      .info-card {
        padding: 1.5rem 1.4rem 1.6rem;
        border-radius: 1.25rem;
      }

      .info-title {
        font-size: 1.6rem;
      }

      .form-row-inline {
        flex-direction: column;
      }

      .vehicle-type-group {
        flex-direction: row;
      }

      .actions {
        flex-direction: column;
        align-items: stretch;
      }

      .btn-secondary,
      .forgot-link {
        text-align: center;
      }
    }
  </style>
</head>
<body>
  <div class="auth-wrapper">
    <!-- LEFT INFO PANEL -->
    <section class="info-card">
      <div class="badge">
        <span class="badge-dot"></span>
        Smart Parking Access
      </div>

      <h1 class="info-title">
        Welcome to <span class="info-highlight">K-Slot Access</span>
      </h1>
      <p class="info-subtitle">
        Sign in or create an account to manage your vehicles, track parking usage,
        and enjoy a frictionless entry experience—every time you drive in.
      </p>

      <div class="info-stats">
        <div class="stat">
          <div class="stat-value">5k+</div>
          <div class="stat-label">Active Users</div>
        </div>
        <div class="stat">
          <div class="stat-value">13</div>
          <div class="stat-label">Secure Zones</div>
        </div>
        <div class="stat">
          <div class="stat-value">24/7</div>
          <div class="stat-label">Access Control</div>
        </div>
      </div>

      <div class="pill-row">
        <div class="pill">
          Tailored for <strong>2-wheelers</strong> &amp; <strong>4-wheelers</strong>
        </div>
        <div class="pill">
          Encrypted <strong>login</strong> &amp; <strong>vehicle mapping</strong>
        </div>
        <div class="pill">
          Instant <strong>QR / Gate</strong> validation
        </div>
      </div>
    </section>

    <!-- RIGHT AUTH PANEL -->
    <section class="auth-card">
      <div class="auth-card-inner">
        <header class="brand">
          <div class="brand-logo">DA</div>
          <div class="brand-text">Kiitdrive Access Portal</div>
        </header>

        <!-- radios moved outside .tabs so ~ selectors work -->
        <input type="radio" name="tab" id="tab-login" class="tab-input" checked />
        <input type="radio" name="tab" id="tab-signup" class="tab-input" />

        <!-- Tabs -->
        <div class="tabs">
          <label class="tab-label" for="tab-login">
            <span>
              <span class="dot"></span>
              Login
            </span>
          </label>

          <label class="tab-label" for="tab-signup">
            <span>
              <span class="dot"></span>
              Sign Up
            </span>
          </label>
        </div>

        <!-- Forms (pure CSS toggle) -->
        <div class="form-outer">
          <!-- LOGIN FORM -->
          <form class="form-panel form-login">
            <h2 class="form-title">Welcome back 👋</h2>
            <p class="form-desc">
              Log in using your registered email / phone number to access your dashboard.
            </p>

            <div class="form-row">
              <label class="form-label" for="login-identifier">
                <span class="main">Email / Phone</span>
              </label>
              <input
                id="login-identifier"
                type="text"
                class="form-input"
                placeholder="you@example.com or +91-9876543210"
                required
              />
            </div>

            <div class="form-row">
              <label class="form-label" for="login-password">
                <span class="main">Password</span>
                <a href="#" class="forgot-link">Forgot password?</a>
              </label>
              <input
                id="login-password"
                type="password"
                class="form-input"
                placeholder="••••••••"
                required
              />
            </div>

            <div class="actions">
              <button type="submit" class="btn-primary">
                Login
                <span>→</span>
              </button>

              <button type="button" class="btn-secondary">
                New here? Sign up
              </button>
            </div>

            <div class="mini-note">
              Make sure you’re using the same email / phone you used during sign up.
            </div>
          </form>

          <!-- SIGNUP FORM -->
          <form class="form-panel form-signup">
            <h2 class="form-title">Create your account 🚗</h2>
            <p class="form-desc">
              Register once, and use the same login for all supported parking zones.
            </p>

            <div class="form-row">
              <label class="form-label" for="signup-identifier">
                <span class="main">Email / Phone</span>
              </label>
              <input
                id="signup-identifier"
                type="text"
                class="form-input"
                placeholder="you@example.com or +91-9876543210"
                required
              />
            </div>

            <div class="form-row form-row-inline">
              <div style="flex: 1;">
                <label class="form-label" for="signup-password">
                  <span class="main">Password</span>
                </label>
                <input
                  id="signup-password"
                  type="password"
                  class="form-input"
                  placeholder="Create a password"
                  required
                />
                <div class="form-helper">
                  Use at least 8 characters with letters &amp; numbers.
                </div>
              </div>

              <div style="flex: 1;">
                <label class="form-label" for="signup-confirm-password">
                  <span class="main">Confirm Password</span>
                </label>
                <input
                  id="signup-confirm-password"
                  type="password"
                  class="form-input"
                  placeholder="Re-enter password"
                  required
                />
              </div>
            </div>

            <div class="form-row form-row-inline">
              <div style="flex: 1;">
                <label class="form-label" for="vehicle-number">
                  <span class="main">Vehicle Number</span>
                </label>
                <input
                  id="vehicle-number"
                  type="text"
                  class="form-input"
                  placeholder="e.g. OD02 AB 1234"
                  required
                />
              </div>

              <div style="flex: 1;">
                <label class="form-label">
                  <span class="main">Vehicle Type</span>
                </label>
                <div class="vehicle-type-group">
                  <label class="vehicle-chip">
                    <input type="radio" name="vehicle-type" value="2-wheeler" checked />
                    <div class="chip-inner">
                      <span class="icon">🛵</span>
                      <span class="text">2-WHEELER</span>
                    </div>
                  </label>

                  <label class="vehicle-chip">
                    <input type="radio" name="vehicle-type" value="4-wheeler" />
                    <div class="chip-inner">
                      <span class="icon">🚗</span>
                      <span class="text">4-WHEELER</span>
                    </div>
                  </label>
                </div>
              </div>
            </div>

            <div class="agreement">
              By signing up, you agree to our
              <a href="#">Terms</a> &amp; <a href="#">Privacy Policy</a>.
            </div>

            <div class="actions">
              <button type="submit" class="btn-primary">
                Sign Up
                <span>✓</span>
              </button>
              <a href="#" class="forgot-link">Already have an account? Login</a>
            </div>

            <div class="divider">Vehicle mapping enabled</div>
            <div class="mini-note">
              You can add or update more vehicles later from your profile settings.
            </div>
          </form>
        </div>
      </div>
    </section>
  </div>
</body>
</html>
